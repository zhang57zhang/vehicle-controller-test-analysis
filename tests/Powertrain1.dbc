BS_:

BU_: VCU MCU BMS DCDC OBD

// ==================== VCU Messages (0x100-0x1FF) ====================

BO_ 0x100 VCU_Status1: 8 VCU
 SG_ VCU_State : 0|4@1+ (1,0) [0|15] ""  VCU
 SG_ Ignition_Status : 4|2@1+ (1,0) [0|3] ""  VCU
 SG_ Ready_Status : 6|2@1+ (1,0) [0|3] ""  VCU
 SG_ Reserved1 : 8|20@1+ (1,0) [0|1048575] ""  VCU
 SG_ Rolling_Counter : 28|4@1+ (1,0) [0|15] ""  VCU
 SG_ CRC8 : 32|8@1+ (1,0) [0|255] ""  VCU

BO_ 0x101 VCU_Vehicle_Status: 8 VCU
 SG_ Vehicle_Speed : 0|12@1+ (0.01,0) [0|100] "km/h"  VCU
 SG_ Gear_State : 12|3@1+ (1,0) [0|7] ""  VCU
 SG_ Drive_Mode : 15|2@1+ (1,0) [0|3] ""  VCU
 SG_ Brake_Pedal_Pos : 20|8@1+ (0.5,0) [0|100] "%"  VCU
 SG_ Accel_Pedal_Pos : 28|8@1+ (0.5,0) [0|100] "%"  VCU
 SG_ Reserved1 : 36|8@1+ (1,0) [0|255] ""  VCU
 SG_ Reserved2 : 44|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8 : 52|8@1+ (1,0) [0|255] ""  VCU

BO_ 0x102 VCU_Control_Cmd1: 8 VCU
 SG_ Target_Torque : 0|12@1- (0.1,0) [-300|300] "Nm"  MCU
 SG_ Target_Speed : 12|12@1+ (1,0) [0|15000] "rpm"  MCU
 SG_ Torque_Enable : 24|1@1+ (1,0) [0|1] ""  MCU
 SG_ Inverter_Enable : 25|1@1+ (1,0) [0|1] ""  MCU
 SG_ Reverse_Enable : 26|1@1+ (1,0) [0|1] ""  MCU
 SG_ Reserved1 : 27|1@1+ (1,0) [0|1] ""  VCU
 SG_ Reserved2 : 28|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8 : 36|8@1+ (1,0) [0|255] ""  VCU
 SG_ Reserved3 : 44|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8_2 : 52|8@1+ (1,0) [0|255] ""  VCU

BO_ 0x103 VCU_Control_Cmd2: 8 VCU
 SG_ Discharge_Current_Limit : 0|12@1+ (0.1,0) [0|400] "A"  BMS
 SG_ Charge_Current_Limit : 12|12@1+ (0.1,0) [0|400] "A"  BMS
 SG_ HV_Loop_Enable : 24|1@1+ (1,0) [0|1] ""  BMS
 SG_ Precharge_Enable : 25|1@1+ (1,0) [0|1] ""  BMS
 SG_ Main_Relay_Cmd : 26|1@1+ (1,0) [0|1] ""  BMS
 SG_ Reserved1 : 27|1@1+ (1,0) [0|1] ""  VCU
 SG_ Reserved2 : 28|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8 : 36|8@1+ (1,0) [0|255] ""  VCU
 SG_ Reserved3 : 44|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8_2 : 52|8@1+ (1,0) [0|255] ""  VCU

BO_ 0x104 VCU_DCDC_Cmd: 8 VCU
 SG_ DCDC_Enable_Cmd : 0|1@1+ (1,0) [0|1] ""  DCDC
 SG_ Target_Output_Voltage : 8|12@1+ (0.01,0) [10|16] "V"  DCDC
 SG_ Target_Output_Current : 20|8@1+ (0.1,0) [0|200] "A"  DCDC
 SG_ Reserved1 : 28|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8 : 36|8@1+ (1,0) [0|255] ""  VCU
 SG_ Reserved2 : 44|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8_2 : 52|8@1+ (1,0) [0|255] ""  VCU

BO_ 0x105 VCU_Diagnostics1: 8 VCU
 SG_ DTC_Count : 0|8@1+ (1,0) [0|255] ""  VCU
 SG_ DTC_1 : 8|16@1+ (1,0) [0|65535] ""  VCU
 SG_ Warning_Level : 24|3@1+ (1,0) [0|7] ""  VCU
 SG_ System_Fault : 27|1@1+ (1,0) [0|1] ""  VCU
 SG_ Reserved1 : 28|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8 : 36|8@1+ (1,0) [0|255] ""  VCU
 SG_ Reserved2 : 44|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8_2 : 52|8@1+ (1,0) [0|255] ""  VCU

BO_ 0x106 VCU_Diagnostics2: 8 VCU
 SG_ DTC_2 : 0|16@1+ (1,0) [0|65535] ""  VCU
 SG_ DTC_3 : 16|16@1+ (1,0) [0|65535] ""  VCU
 SG_ DTC_4 : 32|16@1+ (1,0) [0|65535] ""  VCU
 SG_ Reserved1 : 48|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8 : 56|8@1+ (1,0) [0|255] ""  VCU

BO_ 0x107 VCU_Energy: 8 VCU
 SG_ Trip_Energy : 0|16@1+ (0.01,0) [0|100] "kWh"  VCU
 SG_ Total_Energy : 16|16@1+ (0.01,0) [0|1000] "kWh"  VCU
 SG_ Regenerative_Energy : 32|16@1+ (0.01,0) [0|10] "kWh"  VCU
 SG_ Reserved1 : 48|8@1+ (1,0) [0|255] ""  VCU
 SG_ CRC8 : 56|8@1+ (1,0) [0|255] ""  VCU

BO_ 0x108 VCU_Timestamp: 8 VCU
 SG_ UTC_Time_0 : 0|8@1+ (1,0) [0|255] ""  VCU
 SG_ UTC_Time_1 : 8|8@1+ (1,0) [0|255] ""  VCU
 SG_ UTC_Time_2 : 16|8@1+ (1,0) [0|255] ""  VCU
 SG_ UTC_Time_3 : 24|8@1+ (1,0) [0|255] ""  VCU
 SG_ Rolling_Counter : 32|4@1+ (1,0) [0|15] ""  VCU
 SG_ Reserved1 : 36|12@1+ (1,0) [0|4095] ""  VCU
 SG_ CRC8 : 48|8@1+ (1,0) [0|255] ""  VCU

// ==================== MCU Messages (0x200-0x2FF) ====================

BO_ 0x200 MCU_Status1: 8 MCU
 SG_ MCU_State : 0|4@1+ (1,0) [0|15] ""  MCU
