// ==================== Value Tables ====================

VAL_ 0x100 VCU_State 0 "PowerOff" 1 "Init" 2 "Standby" 3 "Ready" 4 "Run" 5 "Fault" 6 "Shutdown" 15 "Invalid"
VAL_ 0x100 Ignition_Status 0 "OFF" 1 "ACC" 2 "ON" 3 "START"
VAL_ 0x100 Ready_Status 0 "NotReady" 1 "Ready" 2 "Wait" 3 "Error"
VAL_ 0x101 Gear_State 0 "P" 1 "R" 2 "N" 3 "D" 4 "S" 5 "L" 6 "Invalid"
VAL_ 0x101 Drive_Mode 0 "Normal" 1 "Sport" 2 "Eco" 3 "Snow"
VAL_ 0x105 Warning_Level 0 "None" 1 "Info" 2 "Warning" 3 "Error" 4 "Critical" 7 "Invalid"

VAL_ 0x200 MCU_State 0 "Off" 1 "Init" 2 "Standby" 3 "Ready" 4 "Run" 5 "Fault" 15 "Invalid"
VAL_ 0x200 Inverter_State 0 "Off" 1 "Precharge" 2 "Ready" 3 "Run"
VAL_ 0x200 Fault_Level 0 "None" 1 "Warning" 2 "Error" 3 "Critical"

VAL_ 0x300 BMS_State 0 "Off" 1 "Init" 2 "Standby" 3 "Charge" 4 "Discharge" 5 "Fault" 15 "Invalid"
VAL_ 0x300 HV_Loop_State 0 "Open" 1 "Precharge" 2 "Closed" 3 "Fault"
VAL_ 0x300 Relay_State 0 "Open" 1 "Closed"
VAL_ 0x300 Precharge_State 0 "Inactive" 1 "Active"

VAL_ 0x400 DCDC_State 0 "Off" 1 "Init" 2 "Standby" 3 "Run" 4 "Fault" 15 "Invalid"
VAL_ 0x400 Fault_Level 0 "None" 1 "Warning" 2 "Error" 3 "Critical"